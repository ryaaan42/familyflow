{
  "name": "familyflow",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=20.11.1"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @familyflow/web dev",
    "dev:mobile": "pnpm --filter @familyflow/mobile dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "setup": "bash ./scripts/setup.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
